/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>

#include "lotux-pinctrl.dtsi"
#include "lotux-layouts.dtsi"

/ {
    model = "xplotusv0.2";
    compatible = "lotux";

    chosen {
        zephyr,code-partition = &code_partition;
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zmk,physical-layout = &default_layout;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN_MATRIX";

        /* 4 rows: 2 original + 2 hanging keys */
        row-gpios = <
            &gpio0 6 GPIO_ACTIVE_LOW   /* matrix top row */
            &gpio0 2 GPIO_ACTIVE_LOW   /* matrix bottom row */
            &gpio1 4 GPIO_ACTIVE_LOW   /* first hanging key */
            &gpio1 0 GPIO_ACTIVE_LOW   /* second hanging key */
        >;

        /* 5 columns: 3 original + 2 hanging keys */
        col-gpios = <
            &gpio0 10 GPIO_ACTIVE_LOW  /* col0 */
            &gpio0 9  GPIO_ACTIVE_LOW  /* col1 */
            &gpio0 24 GPIO_ACTIVE_LOW  /* col2 */
            &gpio1 6  GPIO_ACTIVE_LOW  /* hanging key 1 */
            &gpio0 11 GPIO_ACTIVE_LOW  /* hanging key 2 */
        >;

        diode-direction = "col2row";
    };

    default_transform: default_transform {
        compatible = "zmk,matrix-transform";
        rows = <4>;
        columns = <5>;

        map = <
            /* row 0 */ RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)
            /* row 1 */ RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)
            /* row 2 */ RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)
            /* row 3 */ RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)
        >;
    };
};